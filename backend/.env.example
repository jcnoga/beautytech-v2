# BEAUTYTECH v2 — Backend .env.example
# Copie para .env e preencha os valores
 
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1
LOG_LEVEL=debug
 
# Supabase
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
 
# SEMPRE Session Pooler IPv4 — senha SEM #$@%
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[SENHA]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require
 
# CORS
CORS_ORIGINS=http://localhost:5173,https://beautytech-v2-frontend.railway.app
 
# WhatsApp Evolution API (opcional)
WHATSAPP_API_URL=https://api.seuservidor.com
WHATSAPP_API_KEY=sua-chave
WHATSAPP_INSTANCE=beautytech-main
 
# Email Resend (opcional)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@beautytech.com.br
RESEND_FROM_NAME=BeautyTech
